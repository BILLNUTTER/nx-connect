# NX-Connect Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nutterxfb

# JWT signing secret (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Express session secret (use a long random string in production)
SESSION_SECRET=your_session_secret_here

# Admin dashboard key (set this to protect the admin panel)
ADMIN_KEY=your_admin_key_here
